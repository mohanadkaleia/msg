# Keep the build context tiny and reproducible. The build needs only
# pyproject.toml, uv.lock, .python-version, server/, and cli/.
.git
.github
.venv
**/__pycache__
**/*.py[cod]
**/*.egg-info
.pytest_cache
.mypy_cache
.ruff_cache
.hypothesis
.claude
docs
data
postgres
*.md
.env
.env.*
# Tests never ship (wheels package only the msgd/msgctl dirs); drop them from
# the context so an edit to a test does not bust the build cache.
server/tests
cli/tests
# Web build inputs the image needs (web/package.json, web/pnpm-lock.yaml, web/src,
# etc.) stay IN the context — the web-builder stage compiles them. But a local
# install/build must NOT leak in: node_modules would bloat the context + can
# defeat --frozen-lockfile reproducibility, and a stale host web/dist could be
# copied over the freshly-built one. The stage rebuilds both from source.
web/node_modules
web/dist
Dockerfile
docker-compose.yml
.dockerignore
.gitignore
.gitattributes
